      "name": "部门管理部门数查询",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 解析响应体为 JSON\r",
              "const responseData = pm.response.json();\r",
              "\r",
              "// 提取 value 值\r",
              "const DeptMaxOrderNum = responseData.value;\r",
              "\r",
              "// 保存到环境变量或全局变量中\r",
              "pm.environment.set(\"DeptMaxOrderNum\", DeptMaxOrderNum);\r",
              "// 或使用全局变量：pm.globals.set(\"DeptMaxOrderNum\", DeptMaxOrderNum);\r",
              "\r",
              "// 可选：打印到控制台验证\r",
              "console.log(\"提取的值：\", DeptMaxOrderNum);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
