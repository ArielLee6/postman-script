    {
      "name": "部门新增",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// 获取当前时间\r",
              "const now = new Date();\r",
              "\r",
              "// 生成 yyyymmdd 格式\r",
              "const year = now.getFullYear();\r",
              "const month = String(now.getMonth() + 1).padStart(2, '0');\r",
              "const day = String(now.getDate()).padStart(2, '0');\r",
              "const dateStr = `${year}${month}${day}`;  // 示例：20260306\r",
              "\r",
              "// 生成 yyyymmddHHMMSS 格式（到秒）\r",
              "const hours = String(now.getHours()).padStart(2, '0');\r",
              "const minutes = String(now.getMinutes()).padStart(2, '0');\r",
              "const seconds = String(now.getSeconds()).padStart(2, '0');\r",
              "const datetimeStr = `${dateStr}${hours}${minutes}${seconds}`;  // 示例：20260306151425\r",
              "\r",
              "// 保存为变量\r",
              "pm.environment.set(\"date_yyyymmdd\", dateStr);\r",
              "pm.environment.set(\"datetime_yyyymmddHHMMSS\", datetimeStr);\r",
              "\r",
              "// 可选：控制台输出验证\r",
              "console.log(\"当前日期(yyyymmdd):\", dateStr);\r",
              "console.log(\"当前时间(yyyymmddHHMMSS):\", datetimeStr);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
